<Window x:Class="FridgeLabReport.ReportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Параметры отчёта"
        Height="385"
        Width="560"
        ResizeMode="NoResize"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,12">
            <MenuItem Header="Файл">
                <MenuItem Header="Сохранить как настройки по умолчанию"
                          Click="MiSaveDefaults_Click"/>
                <MenuItem Header="Сбросить сохранённые настройки"
                          Click="MiResetDefaults_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,10,10"
                       VerticalAlignment="Center"
                       Text="ФИО лаборанта"/>
            <TextBox x:Name="TbLabAssistant"
                     Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,10,10"
                       VerticalAlignment="Center"
                       Text="Название испытания"/>
            <TextBox x:Name="TbTestName"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,0,0,10"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,10,10"
                       VerticalAlignment="Center"
                       Text="Минимальная мощность"/>
            <TextBox x:Name="TbMinPower"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="0,0,0,10"
                     ToolTip="Если поле пустое, подсветка по мощности отключена"/>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,10,10"
                       VerticalAlignment="Center"
                       Text="Минимальная Tcompr"/>
            <TextBox x:Name="TbMinTCompressor"
                     Grid.Row="3"
                     Grid.Column="1"
                     Margin="0,0,0,10"
                     ToolTip="Если поле пустое, подсветка по Tcompr отключена"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,10,10"
                       VerticalAlignment="Center"
                       Text="Минимальное значение всех T"/>
            <TextBox x:Name="TbMinAllT"
                     Grid.Row="4"
                     Grid.Column="1"
                     Margin="0,0,0,10"
                     ToolTip="Если поле пустое, подсветка перехода всех потоков T за указанное отключена"/>

            <TextBlock Grid.Row="5"
                       Grid.Column="1"
                       Foreground="Gray"
                       Text="Снизу — сохранить только для текущего отчёта. Через меню сверху — сохранить как настройки по умолчанию."/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="100"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Сохранить"
                    Click="BtnSave_Click"/>
            <Button Width="100"
                    Height="30"
                    Content="Отмена"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
